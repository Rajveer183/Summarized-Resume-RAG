# ============================================================
# Resume Generation RAG App — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----------------------------
# NVIDIA API (NIM) Settings
# Get your key at: https://build.nvidia.com/
# ----------------------------
NVIDIA_API_KEY=your_nvidia_api_key_here

# NVIDIA NIM base URL (OpenAI-compatible endpoint)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use for resume generation
# Options: meta/llama-3.1-70b-instruct | nvidia/llama-3.1-nemotron-70b-instruct | mistralai/mixtral-8x7b-instruct-v0.1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ----------------------------
# Dataset & Storage Paths
# (relative to project root)
# ----------------------------
DATA_PATH=data/data

# ChromaDB persistence directory
CHROMA_PERSIST_PATH=backend/chroma_db

# Generated resumes output directory
GENERATED_RESUMES_PATH=backend/generated_resumes

# ----------------------------
# Hugging Face (faster model downloads, higher rate limits)
# Get a token at: https://huggingface.co/settings/tokens
# ----------------------------
HF_TOKEN=your_huggingface_token_here

# ----------------------------
# Embedding Model
# ----------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----------------------------
# Ingestion Performance (~15 min full dataset)
# ----------------------------
INGEST_PDF_WORKERS=12
INGEST_EMBED_BATCH_SIZE=256
INGEST_UPSERT_BATCH_SIZE=512
INGEST_FAST_PDF=true
# Set true to wipe ChromaDB before ingest (recommended after HNSW errors)
INGEST_RESET_DB=false

# ----------------------------
# Generation Parameters
# ----------------------------
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=3000

# ----------------------------
# Retrieval Parameters
# ----------------------------
RETRIEVAL_TOP_K=12
RETRIEVAL_FETCH_K=30
RERANKER_TOP_N=7

# ----------------------------
# Server Settings
# ----------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
